<Window x:Class="Mooseware.TimeToAir.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ctrl="clr-namespace:Mooseware.TimeToAir.Controls"
        xmlns:local="clr-namespace:Mooseware.TimeToAir"
        mc:Ignorable="d"
        Title="TimeToAir"
        Height="470"
        Width="670"
        MinHeight="470"
        MinWidth="670"
        MaxHeight="470"
        MaxWidth="670"
        Background="{StaticResource DarkBackgroundBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Icon="/Resources/TimeToAirIcon.png">
    <TabControl x:Name="TabList"
                TabStripPlacement="Bottom"
                Margin="0,0,0,0">
        <TabItem x:Name="CountdownTab"
                 Header="Countdown">
            <Grid x:Name="CountdownContainerGrid"
                  Margin="8 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <GroupBox x:Name="CountdownHeroGroupBox"
                          Header="Countdown"
                          Grid.Row="0"
                          Grid.Column="0">
                    <Grid x:Name="CountdownHeroGrid"
                          Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatusIndicatorBorder"
                                Grid.Row="0"
                                Grid.Column="0"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="100"
                                Height="100"
                                MouseDown="StatusIndicatorBorder_MouseDown">
                            <Grid>
                                <TextBlock  x:Name="StatusLightCaptionText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0 4 0 0"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Text="Status" />
                                <TextBlock  x:Name="StatusLightText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Text="Caution" />
                            </Grid>
                        </Border>
                        <Border x:Name="ModeIndicatorBorder"
                                Grid.Row="0"
                                Grid.Column="2"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="100"
                                Height="100"
                                MouseDown="ModeIndicatorBorder_MouseDown">
                            <Grid>
                                <TextBlock  x:Name="ModeLightCaptionText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0 4 0 0"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Text="Go Live Mode" />
                                <TextBlock  x:Name="ModeLightText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Text="Manual" />
                            </Grid>
                        </Border>
                        <Border x:Name="CountdownIndicatorBorder"
                                Grid.Row="0"
                                Grid.Column="4"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="100"
                                Height="100"
                                MouseDown="CountdownIndicatorBorder_MouseDown">
                            <Grid>
                                <TextBlock  x:Name="CountdownLightCaptionText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0 4 0 0"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Text="Countdown" />
                                <TextBlock  x:Name="CountdownLightText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Text="Hidden" />
                            </Grid>
                        </Border>
                        <Border x:Name="TimeToAirIndicatorBorder"
                                Grid.Row="0"
                                Grid.Column="6"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="210"
                                Height="100">
                            <Grid>
                                <TextBlock  x:Name="TimeToAirLightCaptionText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0 4 0 0"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Text="Time to Air" />
                                <TextBlock  x:Name="TimeToAirMessage"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="48"
                                            FontWeight="Bold"
                                            Text="TBD" />
                            </Grid>
                        </Border>
                        <Button Name="TestStatusButton"
                                Grid.Row="2"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="TestStatusButton_Click"
                                Width="100"
                                Height="50"
                                Content="Test"
                                FontSize="22"
                                IsEnabled="False"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                Style="{StaticResource RunButtonStyle}" />
                        <Button Name="GoLiveModeButton"
                                Grid.Row="2"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="GoLiveModeButton_Click"
                                Width="100"
                                Height="50"
                                Content="Mode"
                                FontSize="22"
                                IsEnabled="False"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                Style="{StaticResource RunButtonStyle}" />
                        <Button Name="RunButton"
                                Grid.Row="2"
                                Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                IsEnabled="False"
                                Click="RunButton_Click"
                                Width="100"
                                Height="50"
                                Content="Show"
                                FontSize="22"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                Style="{StaticResource RunButtonStyle}" />
                        <Border x:Name="OnAirLightBorder"
                                Grid.Row="2"
                                Grid.Column="6"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="120"
                                Height="50"
                                Margin="10,5,5,5"
                                VerticalAlignment="Center">
                            <TextBlock  x:Name="OnAirLightText"
                                        Foreground="{StaticResource DisabledMainBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="26"
                                        FontWeight="Bold"
                                        Text="ON AIR" />
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="7">
                            <TextBlock  x:Name="NextStreamCountdownLabelText"
                                        Foreground="{StaticResource DisabledMainBrush}"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Next scheduled livestream:" />
                            <TextBlock  x:Name="NextStreamCountdownText"
                                        Foreground="{StaticResource DisabledMainBrush}"
                                        Margin="12 0 0 0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        TextTrimming="CharacterEllipsis"
                                        Text="(Next livestream to be determined)"
                                        MaxWidth="425" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
                <Grid x:Name="CountdownControlsGrid"
                      Grid.Row="1"
                      Grid.Column="0"
                      Margin="0 5 0 0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <GroupBox x:Name="StartingCamPresetGroupBox"
                              Header="Starting Camera Presets"
                              Grid.Row="0"
                              Grid.Column="0"
                              Margin="0 0 8 0">
                        <Grid x:Name="StartingPtzSetupGrid"
                              Margin="5 8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Name="PtzPreset1SetButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Click="PtzPreset1SetButton_Click"
                                    Width="80"
                                    Height="70"
                                    IsEnabled="False"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource RunButtonStyle}">
                                <TextBlock x:Name="SetPtzSetup1ButtonText"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Setup 1"
                                           Foreground="{StaticResource Button.Disabled.Foreground}" />
                            </Button>
                            <Button Name="PtzPreset2SetButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="8 0 0 0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Click="PtzPreset2SetButton_Click"
                                    Width="80"
                                    Height="70"
                                    IsEnabled="False"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource RunButtonStyle}">
                                <TextBlock x:Name="SetPtzSetup2ButtonText"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Setup 2"
                                           Foreground="{StaticResource Button.Disabled.Foreground}" />
                            </Button>
                            <Button Name="PtzPreset3SetButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="8 0 0 0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Click="PtzPreset3SetButton_Click"
                                    Width="80"
                                    Height="70"
                                    IsEnabled="False"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource RunButtonStyle}">
                                <TextBlock x:Name="SetPtzSetup3ButtonText"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Setup 3"
                                           Foreground="{StaticResource Button.Disabled.Foreground}" />
                            </Button>
                            <Button Name="PtzPreset4SetButton"
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Margin="8 0 0 0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Click="PtzPreset4SetButton_Click"
                                    Width="80"
                                    Height="70"
                                    IsEnabled="False"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource RunButtonStyle}">
                                <TextBlock x:Name="SetPtzSetup4ButtonText"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Setup 4"
                                           Foreground="{StaticResource Button.Disabled.Foreground}" />
                            </Button>
                            <StackPanel Orientation="Vertical"
                                        Grid.Row="0"
                                        Grid.Column="4"
                                        Margin="14 0 0 0"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="PtzPresetCamera1Label"
                                           Text="Camera 1:"
                                           Foreground="{StaticResource DisabledMainBrush}"
                                           FontSize="16"
                                           FontWeight="Normal" />
                                <TextBlock x:Name="PtzPresetCamera2Label"
                                           Text="Camera 2:"
                                           Foreground="{StaticResource DisabledMainBrush}"
                                           FontSize="16"
                                           FontWeight="Normal" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical"
                                        Grid.Row="0"
                                        Grid.Column="5"
                                        Margin="4 0 0 0"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="PtzPresetCamera1Preset"
                                           Foreground="{StaticResource DisabledMainBrush}"
                                           FontSize="16"
                                           FontWeight="Normal"><Run Text="Preset " /><Run Language="en-ca"
                                                                                          Text="-" /></TextBlock>
                                <TextBlock x:Name="PtzPresetCamera2Preset"
                                           Foreground="{StaticResource DisabledMainBrush}"
                                           FontSize="16"
                                           FontWeight="Normal"><Run Text="Preset " /><Run Language="en-ca"
                                                                                          Text="-" /></TextBlock>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                    <GroupBox x:Name="CountdownSoundGroupBox"
                              Header="Sound"
                              Grid.Row="0"
                              Grid.Column="2">
                        <Border x:Name="SoundIndicatorBorder"
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="4"
                                Background="{StaticResource Button.Disabled.Background}"
                                BorderThickness="3"
                                BorderBrush="{StaticResource DisabledMainBrush}"
                                Width="80"
                                Height="80"
                                MouseDown="SoundIndicatorBorder_MouseDown">
                            <Grid>
                                <TextBlock  x:Name="SoundLightText"
                                            Foreground="{StaticResource DisabledMainBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Text="Mute" />
                            </Grid>
                        </Border>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>
        <TabItem x:Name="ConnectionsTab"
                 Header="Connections">
            <Grid x:Name="ConnectionsContainerGrid"
                  Margin="8 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <GroupBox x:Name="AtemOptionsGroup"
                          Header="Video Switcher Connection"
                          Grid.Column="0"
                          Grid.Row="0"
                          Grid.RowSpan="3">
                    <Grid x:Name="AtemOptionsGrid"
                          Margin="0,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="ATEM IP Address" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="AtemIpAddressTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="192.168.0.240"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="AtemApiStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Content="Countdown Input" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="CountdownInputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="PC4"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="CountdownInputStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Content="Title Card Input" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="TitleCardInputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="MP1"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="TitleCardStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="3"
                               Grid.Column="0"
                               Content="Camera 1 Input" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="Camera1InputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="CAM1"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="Cam1StatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="4"
                               Grid.Column="0"
                               Content="Camera 2 Input" />
                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="Camera2InputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="CAM2"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="Cam2StatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="5"
                               Grid.Column="0"
                               Content="Auxillary Output" />
                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="AuxOutputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     IsReadOnly="True"
                                     IsEnabled="False"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="AUX"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="AuxOutStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="6"
                               Grid.Column="0"
                               Content="Preview Output" />
                        <StackPanel Grid.Row="6"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="PvwOutputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     IsReadOnly="True"
                                     IsEnabled="False"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="PVW"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="PvwOutStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Label Grid.Row="7"
                               Grid.Column="0"
                               Content="Program Output" />
                        <StackPanel Grid.Row="7"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="PgmOutputTextBox"
                                     Width="95"
                                     MaxHeight="21"
                                     IsReadOnly="True"
                                     IsEnabled="False"
                                     Margin="0,2,0,2"
                                     HorizontalAlignment="Left"
                                     Text="PGM"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="PgmOutStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Button x:Name="RefreshAtemConnectionButton"
                                Width="24"
                                Height="24"
                                Margin="10 0 0 0"
                                Grid.Row="0"
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                Click="RefreshAtemConnectionButton_Click"
                                ToolTip="Refresh ATEM Connection"
                                Visibility="Visible">
                            <Image Source="/Resources/Refresh-Button-Icon.png"
                                   Stretch="Fill" />
                        </Button>
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="WebPresenterOptionsGroup"
                          Header="Streaming Bridge Connection"
                          Grid.Row="0"
                          Grid.Column="2">
                    <Grid x:Name="WebPresenterOptionsGrid"
                          Margin="0,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="WebPresenter IP Address" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="WebPresenterIpAddressTextBox"
                                     Width="95"
                                     Height="21"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Text="192.168.0.240"
                                     TextAlignment="Left" />
                            <ctrl:LightEmittingDiode x:Name="WebPresenterApiStatusLed"
                                                     Width="17"
                                                     Height="17"
                                                     Margin="6,0,0,0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     BorderThickness="2"
                                                     SelectedColour="White"
                                                     IsOn="False" />
                        </StackPanel>
                        <Button x:Name="RefreshWebPresenterConnectionButton"
                                Width="26"
                                Height="26"
                                Margin="10 0 0 0"
                                Grid.Row="0"
                                Grid.Column="2"
                                HorizontalAlignment="Left"
                                Click="RefreshWebPresenterConnectionButton_Click"
                                ToolTip="Refresh WebPresenter Connection"
                                Visibility="Visible">
                            <Image Source="/Resources/Refresh-Button-Icon.png"
                                   Stretch="Fill" />
                        </Button>
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="HyperDeckOptionsGroup"
                          Header="Recorder Connection"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="0 4 0 0">
                    <Grid x:Name="HyperDeckOptionsGrid"
                          Margin="0,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Content="HyperDeck IP Address" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox x:Name="HyperDeckIpAddressTextBox"
                                     Width="95"
                                     Height="21"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Text="192.168.0.240"
                                     TextAlignment="Left" />
